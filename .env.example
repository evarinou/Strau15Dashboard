# Dashboard Port (default: 3001)
DASHBOARD_PORT=3001

# --- Pflicht (BFF, serverseitig — Tokens erreichen den Browser nicht mehr) ---
HA_URL=http://strau15machine:8123
HA_TOKEN=your-long-lived-access-token
CHOREQUEST_URL=http://strau15machine:8007
CHOREQUEST_TOKEN=your-chorequest-api-token

# --- Optional (Phase 2 — fehlende Werte deaktivieren nur das Feature) ---
ANTHROPIC_API_KEY=
IMMICH_URL=
IMMICH_API_KEY=
# Optional: nur Fotos mit diesen Personen, z.B. "Eva-Maria,Lukas"
# (Namen wie in Immich vergeben; leer = alle Fotos des Tages)
IMMICH_PEOPLE=
VIKUNJA_URL=
VIKUNJA_TOKEN=
VIKUNJA_PROJECT=Strau15
PAPERLESS_URL=
PAPERLESS_TOKEN=

# --- Optional (Phase 3, Medien-Seite — je fehlendem Paar deaktiviert sich
#     nur der jeweilige Bereich) ---
JELLYFIN_URL=
JELLYFIN_API_KEY=
# Optional: Name des Jellyfin-Haushalts-Accounts (leer = erster/einziger User)
JELLYFIN_USER=
SONARR_URL=
SONARR_API_KEY=
RADARR_URL=
RADARR_API_KEY=
SEERR_URL=
SEERR_API_KEY=

# --- Öffentliche URLs für Links im Browser (optional) ---
# Die internen URLs oben nutzt der BFF für seine API-Aufrufe; diese hier
# stehen in den anklickbaren Links. Leer = Link zeigt auf die interne URL.
HA_PUBLIC_URL=https://ha.strau15.de
IMMICH_PUBLIC_URL=https://immich.strau15.de
PAPERLESS_PUBLIC_URL=https://paperless.strau15.de
VIKUNJA_PUBLIC_URL=
CHOREQUEST_PUBLIC_URL=
JELLYFIN_PUBLIC_URL=
SEERR_PUBLIC_URL=

# --- Zugriffsschutz (nötig, sobald das Dashboard aus dem Internet erreichbar ist) ---
# Siehe SICHERHEIT.md. Leer = kein Schutz (nur für reine LAN-Installationen).
AUTH_HEADER=Remote-User
# Anzahl Reverse-Proxy-Hops vor dem BFF. NIEMALS "true" (Herkunft wäre fälschbar).
TRUST_PROXY=1
BRIEFING_TTL_HOURS=6
